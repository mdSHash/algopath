# Database — local SQLite by default
DATABASE_URL="file:./dev.db"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-strong-random-string"
AUTH_SECRET="replace-with-strong-random-string"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google Gemini — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Optional: model override. Defaults to gemini-2.0-flash if unset.
# GEMINI_MODEL="gemini-2.5-flash"

# Optional: code execution backend. Defaults to "local" (spawns python/node/java).
# Set to "piston" with PISTON_URL pointed at a self-hosted Piston instance for sandboxed execution.
# EXEC_BACKEND="local"
# PISTON_URL="https://your-piston.example.com/api/v2/piston/execute"
